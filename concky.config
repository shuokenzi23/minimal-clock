conky.config = {
    background = true,
    update_interval = 1.0,
    cpu_avg_samples = 2,
    net_avg_samples = 2,
    no_buffers = true,

    alignment = 'middle_right',
    gap_x = 300,
    gap_y = 200,
    minimum_width = 1000,
    minimum_height = 250,
    maximum_width = 1000,

    own_window = true,
    own_window_class = 'Conky',
    own_window_type = 'normal',
    own_window_transparent = true,
    own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',

    use_xft = true,
    uppercase = true,
    xftalpha = 1,
    draw_shades = false,
    draw_outline = false,
    draw_borders = false,
    draw_graph_borders = false,

    default_color = 'white',
};

conky.text = [[
${alignc}${font Anurati:size=60}${time %A}${font}

${voffset 10}${alignc}${font Sans:size=30}${time %I : %M}${font}
]];
